rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profile pictures: any signed-in user can view them (officers need to
    // see a citizen's photo at the counter), but a user may only upload or
    // remove their own.
    match /profile_pictures/{uid}.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Everything else stays locked down by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
